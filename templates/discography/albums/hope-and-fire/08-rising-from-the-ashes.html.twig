{% extends 'base.html.twig' %}

{% block body %}
    <!-- Page Title ============================================= -->
    <section id="page-title" class="page-title-parallax page-title-dark page-title-left"
             style="
                     padding: 250px 0;
                     background-image: url({{ asset('images/wandering-loyalty/2048x1280_phoenix_rising.jpg') }});
                     background-size: cover;
                     background-position: center center;"
             data-bottom-top="background-position:0px 390px;" data-top-bottom="background-position:0px -500px;"
             xmlns="http://www.w3.org/1999/html">

        <div class="container clearfix" style="z-index: 5; white-space: normal;
                                 font-size: 70px; line-height: 50px; font-weight: 900; color: #ffffff;
                                 font-family:Quicksand; text-shadow: 10px 10px 10px #000;">
            <h1>Rising From The Ashes</h1>
            <span style="color: #ffffff; font-weight: bold; font-style: italic;">Hope &amp; Fire (2020)</span>
            <span style="color: #ffffff; font-weight: bold;">Jay Lee Ramsey - Lead Guitar and Vocals</span>
            <span style="color: #ffffff; font-weight: bold;">Vincent Z. Whaley - Lyrics and Rhythm Guitar</span>
            <span style="color: #ffffff; font-weight: bold;">John Skinner - Bass Guitar</span>
            <span style="color: #ffffff; font-weight: bold;">Jason Gross - Percussion</span>
        </div>

    </section><!-- #page-title end -->

    <!-- Content ============================================= -->
    <section id="content">

        <div class="content-wrap">

            <div class="container clearfix">

                <div class="footer-widgets-wrap clearfix"
                     style="margin: 0 auto; text-align: center; padding-bottom:25px;">

                    <p style="font-family:Quicksand; font-size: 27px;">Rising From The Ashes</p>
                    <iframe src="{{ asset('music/silence.mp3') }}" type="audio/mp3" allow="autoplay" id="audio"
                            style="display:none"></iframe>
                    <audio id="audio-player" autoplay controls controlsList="nodownload">
                        <source src="" type="audio/ogg">
                        <source src="{{ asset('music/08_Rising_From_The_Ashes.mp3') }}" type="audio/mp3">
                        Your browser does not support the audio element.
                    </audio>
                    <p style="margin-top:35px;">Copyright &copy; {{ "now"|date("Y") }} All Rights Reserved by Wandering
                        Loyalty and Moon Whale Media Recordings</p>

                </div>

                <div class="nobottommargin">
                    <div class="feature-box media-box">
                        <div class="fbox-media" style="margin: 0 auto; text-align: center;">
                            <p style="font-family:Quicksand; font-size: 18px; color:#333;">
                                Billowing smoke from weeks of doubt.<br/>
                                Flames combust, roaring with a shout.<br/>
                                Birthed by greed, deception and lies.<br/>
                                Reborn into vigilant eyes.
                            </p>
                            <p style="font-family:Quicksand; font-size: 18px; color:#333;">
                                No longer questioning my mind.<br/>
                                Let bad memories leave the throne.<br/>
                                No longer ignoring my spine.<br/>
                                Let tragedy suffer alone.
                            </p>
                            <p style="font-family:Quicksand; font-size: 18px; color:#333;">
                                Rising from the ashes of all past mistakes.<br/>
                                Rising and flying above secrecy’s take.<br/>
                                Rising from the ashes of all the heartbreak.<br/>
                                Rising and flying above betrayal’s wake.
                            </p>
                            <p style="font-family:Quicksand; font-size: 18px; color:#333;">
                                Rise.<br/>
                                Rise above.<br/>
                                Rise above the darkness.<br/>
                                Rise above.<br/>
                                Rise above the heartless.<br/>
                                Rise above.<br/>
                                Rise above the masses.<br/>
                                Rise above.<br/>
                                Rise from the ashes.<br/><br/>
                                Rise!
                            </p>
                            <p style="font-family:Quicksand; font-size: 18px; color:#333;">
                                Never look back, flying forward.<br/>
                                Staying faithful to my new wings.<br/>
                                Thankful for shedding the torture.<br/>
                                Farewell, now listen to me sing.
                            </p>
                            <p style="font-family:Quicksand; font-size: 18px; color:#333;">
                                Rising from the ashes of all past mistakes.<br/>
                                Rising and flying above secrecy’s take.<br/>
                                Rising from the ashes of all the heartbreak.<br/>
                                Rising and flying above betrayal’s wake.
                            </p>
                            <p style="font-family:Quicksand; font-size: 18px; color:#333;">
                                Rise.<br/>
                                Rise above.<br/>
                                Rise above the darkness.<br/>
                                Rise above.<br/>
                                Rise above the heartless.<br/>
                                Rise above.<br/>
                                Rise above the masses.<br/>
                                Rise above.<br/>
                                Rise from the ashes.<br/><br/>
                                Rise!
                            </p>
                            <p style="color:#333; margin-top:35px;">Copyright &copy; {{ "now"|date("Y") }} All Rights
                                Reserved by Wandering
                                Loyalty and Moon Whale Media Recordings</p>
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </section><!-- #content end -->

{% block script %}
    <!-- External JavaScripts
    ============================================= -->
    <script src="{{ asset('js/jquery.js') }}"></script>
    <script src="{{ asset('js/plugins.js') }}"></script>

    <!-- Footer Scripts
    ============================================= -->
    <script src="{{ asset('js/functions.js') }}"></script>

    <!-- SLIDER REVOLUTION 5.x SCRIPTS  -->
    <script src="{{ asset('include/rs-plugin/js/jquery.themepunch.tools.min.js') }}"></script>
    <script src="{{ asset('include/rs-plugin/js/jquery.themepunch.revolution.min.js') }}"></script>
    <!-- SLIDER REVOLUTION ADDONS  -->
    {#<script src="{{ asset('include/rs-plugin/js/addons/revolution.addon.revealer.min.js') }}"></script>#}
    <script src="{{ asset('include/rs-plugin/js/addons/revolution.addon.particles.min.js') }}"></script>
    <!-- SLIDER REVOLUTION EXTENSIONS  -->
    <script src="{{ asset('include/rs-plugin/js/extensions/revolution.extension.actions.min.js') }}"></script>
    <script src="{{ asset('include/rs-plugin/js/extensions/revolution.extension.carousel.min.js') }}"></script>
    <script src="{{ asset('include/rs-plugin/js/extensions/revolution.extension.kenburn.min.js') }}"></script>
    <script src="{{ asset('include/rs-plugin/js/extensions/revolution.extension.layeranimation.min.js') }}"></script>
    <script src="{{ asset('include/rs-plugin/js/extensions/revolution.extension.migration.min.js') }}"></script>
    <script src="{{ asset('include/rs-plugin/js/extensions/revolution.extension.navigation.min.js') }}"></script>
    <script src="{{ asset('include/rs-plugin/js/extensions/revolution.extension.parallax.min.js') }}"></script>
    <script src="{{ asset('include/rs-plugin/js/extensions/revolution.extension.slideanims.min.js') }}"></script>
    <script src="{{ asset('include/rs-plugin/js/extensions/revolution.extension.video.min.js') }}"></script>
    </script>
        {% endblock %}

{% endblock %}
