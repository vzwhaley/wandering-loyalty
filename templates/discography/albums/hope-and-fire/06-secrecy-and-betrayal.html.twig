{% extends 'base.html.twig' %}

{% block body %}
    <!-- Page Title ============================================= -->
    <section id="page-title" class="page-title-parallax page-title-dark page-title-left"
             style="
                     padding: 250px 0;
                     background-image: url({{ asset('images/wandering-loyalty/1920x1080_skull_quill_books.jpg') }});
                     background-size: cover;
                     background-position: center center;"
             data-bottom-top="background-position:0px 390px;" data-top-bottom="background-position:0px -500px;"
             xmlns="http://www.w3.org/1999/html">

        <div class="container clearfix" style="z-index: 5; white-space: normal;
                                 font-size: 70px; line-height: 50px; font-weight: 900; color: #ffffff;
                                 font-family:Quicksand; text-shadow: 10px 10px 10px #000;">
            <h1>Secrecy &amp; Betrayal</h1>
            <span style="color: #ffffff; font-weight: bold; font-style: italic;">Hope &amp; Fire (2020)</span>
            <span style="color: #ffffff; font-weight: bold;">Jay Lee Ramsey - Lead Guitar and Vocals</span>
            <span style="color: #ffffff; font-weight: bold;">Vincent Z. Whaley - Lyrics and Rhythm Guitar</span>
            <span style="color: #ffffff; font-weight: bold;">John Skinner - Bass Guitar</span>
            <span style="color: #ffffff; font-weight: bold;">Jason Gross - Percussion</span>
            <span style="color: #ffffff; font-weight: bold;">Jonathan Franklin - Violin</span>
        </div>

    </section><!-- #page-title end -->

    <!-- Content ============================================= -->
    <section id="content">

        <div class="content-wrap">

            <div class="container clearfix">

                <div class="footer-widgets-wrap clearfix"
                     style="margin: 0 auto; text-align: center; padding-bottom:25px;">

                    <p style="font-family:Quicksand; font-size: 27px;">Secrecy &amp; Betrayal</p>

                    <div class="footer-widgets-wrap clearfix"
                         style="margin: 0 auto; text-align: center; padding-bottom:25px;">

                        <iframe src="{{ asset('music/silence.mp3') }}" type="audio/mp3" allow="autoplay" id="audio"
                                style="display:none"></iframe>
                        <audio id="audio-player" autoplay controls controlsList="nodownload">
                            <source src="" type="audio/ogg">
                            <source src="{{ asset('music/06_Secrecy_&_Betrayal.mp3') }}" type="audio/mp3">
                            Your browser does not support the audio element.
                        </audio>
                        <p style="margin-top:35px;">Copyright &copy; {{ "now"|date("Y") }} All Rights Reserved by Wandering
                            Loyalty and Moon Whale Media Recordings</p>

                    </div>

                    <iframe width="560" height="315" src="https://www.youtube.com/embed/BlHR5zfqMYo" frameborder="0"
                            allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen></iframe>
{#                    <iframe src="{{ asset('music/silence.mp3') }}" type="audio/mp3" allow="autoplay" id="audio"#}
{#                            style="display:none"></iframe>#}
{#                    <audio id="audio-player" autoplay controls controlsList="nodownload">#}
